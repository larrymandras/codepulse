# Convex deployment URL (get from `npx convex dev` or Convex dashboard)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Optional: Convex deploy key for CI/CD
# CONVEX_DEPLOY_KEY=prod:your-key-here

# Clerk authentication (required for Clerk-to-Convex auth bridge)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-key-here

# Email defaults for profile configuration (no real emails in source)
VITE_EMAIL_PERSONAL=
VITE_EMAIL_BUSINESS=
VITE_EMAIL_CONSULTING=

# Astridr WebSocket connection
VITE_ASTRIDR_WS_URL=ws://localhost:8765
VITE_ASTRIDR_API_KEY=

# Ingest API key (server-side only — set in Convex environment variables, not here)
# ASTRIDR_INGEST_API_KEY=your-ingest-key-here
# CODEPULSE_ALLOWED_ORIGIN=http://localhost:5173
